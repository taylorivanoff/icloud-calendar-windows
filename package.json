{
  "name": "icloud-calendar",
  "description": "View your iCloud calendar in a native Windows application.",
  "author": {
    "name": "Taylor Ivanoff"
  },
  "version": "1.0.16",
  "repository": "https://github.com/taylorivanoff/icloud-calendar-windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "release": "electron-builder --win --x64 --publish=never"
  },
  "build": {
    "appId": "io.github.taylorivanoff.icloud-calendar",
    "productName": "iCloud Calendar",
    "win": {
      "icon": "icon.png",
      "target": "nsis",
      "artifactName": "${name}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh",
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/taylorivanoff/icloud-calendar-windows/releases/latest/download"
    },
    "protocols": {
      "name": "iCloud Calendar",
      "schemes": [
        "icloud-calendar"
      ]
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8",
    "icloud-windows-base": "github:taylorivanoff/icloud-windows-base#v1.0.15"
  },
  "devDependencies": {
    "electron": "^30.0.3",
    "electron-builder": "^24.13.3"
  }
}
